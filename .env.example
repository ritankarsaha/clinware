

# REQUIRED — Get yours at https://aistudio.google.com/app/apikey
export GOOGLE_API_KEY=AIza...your-key-here...

# OPTIONAL — Gemini model to use (default: gemini-2.5-flash)
export GEMINI_MODEL=gemini-2.5-flash

# OPTIONAL — MCP server response timeout in milliseconds 
# export MCP_TIMEOUT_MS=15000

# OPTIONAL — How many days back to search news 
# export NEWS_SEARCH_DAYS=30

# OPTIONAL — Absolute path to the built MCP server entry point
#             Default: ~/coding/verge-news-mcp/build/index.js
# export MCP_SERVER_PATH=/path/to/verge-news-mcp/build/index.js
